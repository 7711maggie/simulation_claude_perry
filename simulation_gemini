    subtitle = "n=31, σ=0.1；维度越高，噪声污染越严重，高估加剧",
    x        = "主成分索引 k",
    y        = "log(高估倍数) 中位数",
    color    = "维度 p"
  ) +
  theme_bw(base_size = 13) +
  theme(plot.title = element_text(face = "bold"), legend.position = "bottom")

